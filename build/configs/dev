CONFIG = Debug

OUT_DIR = ./$(CONFIG)
SHARED_DIR = ../sharedlibs/$(CONFIG)

COMPILER_DIR = /usr/bin
COMPILER_BIN_PREFIX =

CC := $(COMPILER_DIR)/$(COMPILER_BIN_PREFIX)cc
CXX := $(COMPILER_DIR)/$(COMPILER_BIN_PREFIX)g++
AR := $(COMPILER_DIR)/$(COMPILER_BIN_PREFIX)ar
AS := $(COMPILER_DIR)/$(COMPILER_BIN_PREFIX)as
LD := $(COMPILER_DIR)/$(COMPILER_BIN_PREFIX)ld
STRIP := $(COMPILER_DIR)/$(COMPILER_BIN_PREFIX)strip

LIB_PATH := -L/usr/local/lib
INCLUDES := -I/usr/local/include

GCC_FLAGS := -O0 -g3 -Wall -c -fmessage-length=0 -fPIC -std=c++14
CC_FLAGS := $(GCC_FLAGS)
LINK_FLAGS = -pthread -llog4cplus
DEFINES =
